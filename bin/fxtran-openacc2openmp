#!/usr/bin/env perl 

use warnings;

use FindBin qw ($Bin);
use lib "$Bin/../lib";
use Fxtran::Common;

use Data::Dumper;
use Getopt::Long;
use FileHandle;
use File::Basename;

use Fxtran::Bt;
use Fxtran;
use Fxtran::Pragma::OpenACCToOpenMPTarget;
use Fxtran::Pragma::OpenACC;

use strict;

my $expand = 1;

if ($ARGV[0] eq '--no-expand')
  {
    $expand = 0;
    shift (@ARGV);
  }

my $F90 = shift;
my $F90out = shift;


mkdir ('expand');
mkdir ('openmptarget');

my $d = &Fxtran::parse (location => $F90, fopts => [qw (-line-length 5000 -no-include 
                        -no-cpp -construct-tag -openacc)]);

for my $pl (&F ('.//parallel-loop-openacc', $d))
  {
    &Fxtran::Pragma::OpenACC::cleanOpenACCParallelLoop ($pl);
  }

if ($expand)
  {
    for my $pl (&F ('.//parallel-loop-openacc', $d))
      {
        &Fxtran::Pragma::OpenACC::expandParallelLoop ($pl);
      }
    
    for my $pa (&F ('.//parallel-openacc|.//serial-openacc', $d))
      {
        &Fxtran::Pragma::OpenACC::expandParallelData ($pa);
      }
  }

if ($F90out && ($F90out eq '-'))
  {
    print $d->textContent;
  }
else
  {
    'FileHandle'->new (">expand/" . &basename ($F90))->print ($d->textContent);
  }

&Fxtran::Pragma::OpenACCToOpenMPTarget::convert ($d);

if ($F90out && ($F90out eq '-'))
  {
    print "---\n";
    print $d->textContent;
  }
else
  {
    'FileHandle'->new (">openmptarget/" . &basename ($F90))->print ($d->textContent);
  }

__END__
if ($F90out)
  {
    'FileHandle'->new (">$F90out")->print ($d->textContent);
  }
else
  {
    print $d->textContent;
  }


